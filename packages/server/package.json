{
  "name": "server",
  "version": "1.0.0",
  "description": "a repo for gathering tokens, networks, and data providers",
  "main": "src/index.ts",
  "private": true,
  "scripts": {
    "setup": "docker compose build && yarn install && yarn run db:start && sleep 5 && yarn run db:migrate-latest && sleep 3 && yarn run db:seed && sleep 3 && DEBUG=📷* NODE_ENV=development yarn run collect && sleep 10 && yarn run create-orders",
    "docker:build": "docker build -t gibsfinance/assets:latest .",
    "docker:push": "docker push gibsfinance/assets:latest",
    "db:prepare": "yarn run db:start && yarn run db:migrate-up",
    "db:start": "docker compose up -d gibassets-postgres",
    "db:stop": "docker compose down",
    "db:migrate-down-all": "tsx ./node_modules/.bin/knex migrate:rollback --all",
    "db:migrate-down": "tsx ./node_modules/.bin/knex migrate:down",
    "db:migrate-rollback": "tsx ./node_modules/.bin/knex migrate:rollback",
    "db:migrate-reset": "yarn run db:migrate-down-all && yarn run db:migrate-latest",
    "db:migrate-up": "tsx src/bin/migrate",
    "db:migrate-latest": "tsx src/bin/migrate",
    "db:migrate-make": "tsx ./node_modules/.bin/knex migrate:make",
    "db:seed-make": "tsx ./node_modules/.bin/knex seed:make",
    "db:seed": "tsx src/bin/seed",
    "build": "tsc",
    "collect": "tsx src/bin/collect",
    "collect:dev": "tsx --watch src/bin/collect",
    "harvest": "tsx src/bin/harvest",
    "server": "tsx ./src/bin/server.ts",
    "dev": "tsx watch ./src/bin/server.ts",
    "lint": "prettier --check . && ESLINT_USE_FLAT_CONFIG=true eslint \"./src/**/*.ts\" -c .eslintrc.mjs",
    "format": "prettier --write \"src/**/*.{ts,js,json}\" \"*.{json,md}\"",
    "create-orders": "tsx src/bin/create-orders",
    "test": "NODE_ENV=test tsx --test --test-reporter=spec --test-reporter-destination=stdout ./test/index.ts",
    "test:exits": "bash test-provider-exits.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/gibsfinance/assets.git"
  },
  "keywords": [
    "images",
    "tokens",
    "crypto",
    "network"
  ],
  "author": "gibsfinancedev",
  "type": "module",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/gibsfinance/assets/issues"
  },
  "homepage": "https://github.com/gibsfinance/assets#readme",
  "devDependencies": {
    "@eslint/js": "^9.4.0",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/debug": "^4.1.12",
    "@types/eslint": "^8.56.10",
    "@types/eslint__js": "^8.42.3",
    "@types/lodash": "^4.17.4",
    "@types/pg": "^8.11.6",
    "@types/puppeteer": "^5.4.7",
    "@types/response-time": "^2.3.8",
    "@types/supertest": "^6.0.2",
    "@types/yargs": "^17.0.32",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-mocha": "^10.4.3",
    "globals": "^15.3.0",
    "prettier": "^3.3.1",
    "supertest": "^7.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^7.12.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@coingecko/coingecko-typescript": "^1.13.0",
    "@gibs/dexscreener": "^1.0.0",
    "@gibs/utils": "^1.0.0",
    "@topcli/spinner": "^2.1.2",
    "@types/body-parser": "^1.19.5",
    "@types/express": "^5.0.1",
    "@types/http-errors": "^2.0.4",
    "@types/react": "^18.2.66",
    "@uniswap/token-lists": "^1.0.0-beta.34",
    "body-parser": "^1.20.2",
    "cheerio": "^1.0.0",
    "coingecko-api-v3": "^0.0.31",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "debug": "^4.3.5",
    "dexscreener-sdk": "^1.0.3",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "express-urlrewrite": "^2.0.2",
    "file-type": "^21.3.1",
    "hardhat": "^2.23.0",
    "http-errors": "^2.0.0",
    "ink": "^4.4.1",
    "knex": "^3.1.0",
    "lodash": "^4.17.21",
    "node-fetch": "^3.3.2",
    "pg": "^8.12.0",
    "promise-limit": "^2.7.0",
    "puppeteer": "^24.20.0",
    "puppeteer-core": "^24.17.1",
    "react": "^18.2.0",
    "response-time": "^2.3.2",
    "sharp": "^0.34.5",
    "tsx": "^4.11.2",
    "viem": "^2.47.5",
    "yargs": "^17.7.2"
  },
  "engines": {
    "node": ">=22"
  }
}
