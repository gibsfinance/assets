{
  "name": "gibassets",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "docker:build": "docker build -t gibsfinance/assets:latest .",
    "docker:push": "docker push gibsfinance/assets:latest",
    "build": "npm run build --workspace=*",
    "collect": "npm run collect --workspace=packages/server",
    "server": "npm run server --workspace=packages/server",
    "frontend:dev": "npm run dev:static --workspace=packages/frontend",
    "frontend:preview": "npm run preview --workspace=packages/frontend",
    "server:dev": "npm run dev --workspace=packages/server",
    "db:up": "docker compose -f docker-compose.yml up -d gibassets-postgres",
    "test": "npm run test --workspace=packages/server",
    "db:migrate-latest": "npm run db:migrate-latest --workspace=packages/server",
    "db:seed": "npm run db:seed --workspace=packages/server",
    "db:migrate-make": "npm run db:migrate-make --workspace=packages/server"
  },
  "workspaces": [
    "packages/utils",
    "packages/dexscreener",
    "packages/server",
    "packages/frontend"
    ],
  "packageManager": "npm@11.2.0",
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.8.3"
  }
}
