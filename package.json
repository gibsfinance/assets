{
  "name": "gibassets",
  "version": "1.0.1",
  "private": true,
  "scripts": {
    "docker:build": "yarn run docker:build:postgres && yarn run docker:build:server",
    "docker:build:server": "docker build -t gibsfinance/assets:latest .",
    "docker:build:postgres": "docker compose build --no-cache postgres",
    "docker:push": "yarn run docker:push:server && yarn run docker:push:postgres",
    "docker:push:server": "docker push gibsfinance/assets:latest",
    "docker:push:postgres": "docker push gibsfinance/postgres:latest",
    "build": "yarn workspace @gibs/utils run build && yarn workspace @gibs/dexscreener run build && yarn workspace ui run build && yarn workspace server run build",
    "collect": "yarn workspace server run collect",
    "server": "yarn workspace server run server",
    "ui:dev": "yarn workspace ui run dev",
    "ui:preview": "yarn workspace ui run preview",
    "server:dev": "yarn workspace server run dev",
    "db:up": "docker compose -f docker-compose.yml up -d postgres",
    "test": "yarn workspace server run test",
    "db:migrate-latest": "yarn workspace server run db:migrate-latest",
    "db:seed": "yarn workspace server run db:seed",
    "cronworker": "/usr/local/bin/update_submodules.sh && yarn workspace server run collect --logger=pretty",
    "db:migrate-make": "yarn workspace server run db:migrate-make"
  },
  "workspaces": [
    "packages/utils",
    "packages/sdk",
    "packages/react",
    "packages/dexscreener",
    "packages/ui",
    "packages/server"
  ],
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.8.3"
  },
  "packageManager": "yarn@4.13.0+sha512.5c20ba010c99815433e5c8453112165e673f1c7948d8d2b267f4b5e52097538658388ebc9f9580656d9b75c5cc996f990f611f99304a2197d4c56d21eea370e7",
  "dependencies": {
    "viem": "^2.47.5"
  },
  "resolutions": {
    "axios": ">=1.15.0",
    "basic-ftp": ">=5.2.2",
    "flatted": ">=3.4.2",
    "lodash": ">=4.18.1",
    "vitest/vite": ">=8.0.5"
  }
}
