{
  "name": "gibassets",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "npm run build --workspace=*",
    "collect": "npm run collect --workspace=packages/server",
    "server": "npm run build && npm run server --workspace=packages/server",
    "frontend:preview": "npm run dev:static --workspace=packages/frontend",
    "server:dev": "npm run dev --workspace=packages/server"
  },
  "workspaces": [
    "packages/utils",
    "packages/dexscreener",
    "packages/server",
    "packages/frontend"
  ],
  "packageManager": "npm@11.2.0",
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
